{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/admissions.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/notifications.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/admision/emergencia",
      "dest": "/api/admissions.py"
    },
    {
      "src": "/api/notifications",
      "dest": "/api/notifications.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=30"
        }
      ]
    }
  ]
}
